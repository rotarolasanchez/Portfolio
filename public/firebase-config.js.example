/**
 * PLANTILLA de configuración de Firebase para la web.
 *
 * INSTRUCCIONES:
 * 1. Copia este archivo como "firebase-config.js" en el mismo directorio
 * 2. Rellena los valores con tu configuración real de Firebase
 * 3. El archivo "firebase-config.js" está en .gitignore y NO se sube al repositorio
 *
 * PRODUCCIÓN (Firebase Hosting):
 * - Opción A: Inyectar en el pipeline de CI/CD (GitHub Actions secret → archivo)
 * - Opción B: Usar Firebase Hosting reserved URLs /__/firebase/init.js
 *
 * CÓMO OBTENER ESTOS VALORES:
 * - Ve a Firebase Console → Configuración del proyecto → Tus apps → Web
 * - Copia el objeto firebaseConfig que aparece
 */
window.__FIREBASE_CONFIG__ = {
    apiKey: "REEMPLAZA_CON_TU_API_KEY_NUEVA",
    authDomain: "TU_PROJECT_ID.firebaseapp.com",
    projectId: "TU_PROJECT_ID",
    storageBucket: "TU_PROJECT_ID.firebasestorage.app"
};

